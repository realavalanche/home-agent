# ─────────────────────────────────────────────────────────────────────────────
# home-agent environment. Copy to `.env` and fill in. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
PORT=8080
# Public HTTPS base URL of this app (used for Google OAuth redirect + webhook).
# Local dev: your cloudflared/ngrok URL, e.g. https://abc123.trycloudflare.com
PUBLIC_BASE_URL=https://your-tunnel-or-domain.example.com
# Fixed timezone for all scheduling / reviews.
TIMEZONE=Asia/Kolkata

# ── Postgres ─────────────────────────────────────────────────────────────────
# Local docker-compose provides this automatically; override for prod.
DATABASE_URL=postgres://homeagent:homeagent@localhost:5432/homeagent

# ── Meta WhatsApp Cloud API ──────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=            # (#1) you have this
WHATSAPP_ACCESS_TOKEN=               # (#2) permanent token, you have this
WHATSAPP_APP_SECRET=                 # (#3) App → Settings → Basic — for signature check
WHATSAPP_VERIFY_TOKEN=               # (#4) invent any random string; used once at webhook setup
WHATSAPP_BUSINESS_ACCOUNT_ID=        # (#5) optional but recommended
WHATSAPP_GRAPH_VERSION=v21.0

# ── The two users (E.164 without '+', e.g. 919876543210) ─────────────────────
USER_A_NAME=Sid
USER_A_WHATSAPP=919999999999
USER_A_GOOGLE_EMAIL=you@gmail.com

USER_B_NAME=Wife
USER_B_WHATSAPP=918888888888
USER_B_GOOGLE_EMAIL=wife@gmail.com

# ── Notion (#7, #8) ──────────────────────────────────────────────────────────
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=               # a page shared with the integration
# Filled in automatically by `npm run setup:notion` (do not edit by hand):
NOTION_DB_CAPTURES=
NOTION_DB_TASKS=
NOTION_DB_WEEKLY=
# Data source ids (Notion API 2025-09-03), also filled by setup:notion:
NOTION_DS_CAPTURES=
NOTION_DS_TASKS=
NOTION_DS_WEEKLY=

# ── Google OAuth (#9) — enable Calendar API + Gmail API in Cloud Console ──────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match an Authorized redirect URI in the OAuth client:
GOOGLE_REDIRECT_URI=https://your-tunnel-or-domain.example.com/oauth/google/callback

# ── AI providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                   # (#11)
SARVAM_API_KEY=                      # (#10)
VOYAGE_API_KEY=                      # (#12)

# ── Model selection (override only if you know why) ──────────────────────────
CLAUDE_AGENT_MODEL=claude-sonnet-5
CLAUDE_REVIEW_MODEL=claude-opus-4-8
VOYAGE_MODEL=voyage-3
SARVAM_STT_MODEL=saarika:v2.5
